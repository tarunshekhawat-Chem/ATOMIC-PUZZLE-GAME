



<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atomic Puzzle - Standalone Edition</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .tile-correct { box-shadow: inset 0 0 12px rgba(34, 197, 94, 0.5); border-color: rgba(22, 101, 52, 0.6) !important; }
        .animate-spin-slow { animation: spin 3s linear infinite; }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        .tile-transition { transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); }
    </style>
</head>
<body class="bg-gradient-to-br from-cyan-600 to-cyan-400 min-h-screen text-white flex flex-col items-center justify-center p-3 sm:p-4 overflow-x-hidden">

    <!-- GAME LOBBY -->
    <div id="lobby" class="w-full max-w-[450px] bg-slate-900/90 backdrop-blur-xl p-8 rounded-3xl border-2 border-cyan-500/30 shadow-2xl text-center">
        <h1 class="text-5xl font-black text-white mb-2 tracking-tighter">ATOMIC PUZZLE</h1>
        <p class="text-cyan-400 font-bold uppercase tracking-widest text-xs mb-8">Select Complexity Level</p>
        
        <div id="level-buttons" class="space-y-4 mb-8">
            <!-- Buttons injected by JS -->
        </div>

        <button onclick="startGame()" class="w-full py-5 bg-gradient-to-r from-yellow-400 to-orange-500 text-slate-900 font-black text-3xl rounded-2xl shadow-[0_6px_0_0_rgba(161,98,7,1)] active:shadow-none active:translate-y-1 transition-all uppercase tracking-tighter">
            Play
        </button>
    </div>

    <!-- GAME BOARD -->
    <div id="game-container" class="hidden w-full max-w-[500px] relative">
        <div class="flex justify-between items-center mb-4 px-1">
            <button onclick="exitToMenu()" class="flex items-center gap-2 px-4 py-2 bg-black/30 hover:bg-black/50 rounded-xl text-xs font-black uppercase border-2 border-white/10 tracking-wider transition-all active:scale-95 shadow-lg">
                <i data-lucide="home" class="w-4 h-4 text-cyan-400"></i>
                <span>Menu</span>
            </button>
            
            <div class="flex items-center gap-3">
                <div id="current-mode" class="bg-black/30 px-4 py-2 rounded-xl text-[10px] font-black uppercase border-2 border-white/10 text-yellow-400 tracking-widest shadow-lg">
                    EASY MODE
                </div>
                <button onclick="toggleHelp(true)" class="p-2 bg-black/30 hover:bg-black/50 rounded-xl transition-all border-2 border-white/10 active:scale-95 shadow-lg">
                    <i data-lucide="help-circle" class="w-5 h-5 text-cyan-400"></i>
                </button>
            </div>
        </div>

        <header class="text-center mb-4 sm:mb-6">
            <h1 class="text-4xl sm:text-6xl font-black mb-1 text-white drop-shadow-lg tracking-tighter">ATOMIC PUZZLE</h1>
            <p class="text-cyan-50 font-bold uppercase tracking-[0.2em] text-[10px] sm:text-xs opacity-90">Periodic Table Challenge</p>
        </header>

        <div class="grid grid-cols-3 gap-3 mb-6">
            <div class="bg-black/20 backdrop-blur-md p-3 rounded-xl flex flex-col items-center justify-center border-2 border-black/30 text-center">
                <div class="flex items-center gap-1.5 mb-1 text-yellow-300 font-bold uppercase text-[10px]">
                    <i data-lucide="hash" class="w-4 h-4"></i> Moves
                </div>
                <span id="move-count" class="text-2xl font-black tabular-nums leading-none">0</span>
            </div>
            <div class="bg-black/20 backdrop-blur-md p-3 rounded-xl flex flex-col items-center justify-center border-2 border-black/30 text-center">
                <div class="flex items-center gap-1.5 mb-1 text-yellow-300 font-bold uppercase text-[10px]">
                    <i data-lucide="clock" class="w-4 h-4"></i> Time
                </div>
                <span id="timer-display" class="text-2xl font-black tabular-nums leading-none">00:00</span>
            </div>
            <button onclick="toggleGuide()" id="guide-btn" class="backdrop-blur-md p-3 rounded-xl flex flex-col items-center justify-center border-2 transition-all active:scale-95 bg-black/20 border-black/30 text-white">
                <div class="flex items-center gap-1.5 mb-1 font-bold uppercase text-[10px]">
                    <i data-lucide="eye" id="guide-icon" class="w-4 h-4 text-yellow-300"></i> Guide
                </div>
                <span id="guide-status" class="text-xs font-black leading-none">OFF</span>
            </button>
        </div>

        <div id="board-wrapper" class="relative w-full bg-black/30 p-1 sm:p-2 rounded-xl shadow-2xl border-[3px] sm:border-4 border-black/40 backdrop-blur-md overflow-hidden">
            <!-- Ghost Layer -->
            <div id="ghost-layer" class="hidden absolute inset-1 sm:inset-2 grid pointer-events-none z-0"></div>
            <!-- Interactive Grid -->
            <div id="puzzle-grid" class="grid h-full relative z-10"></div>
            
            <!-- Win Overlay -->
            <div id="win-overlay" class="hidden absolute inset-0 flex flex-col items-center justify-center bg-black/80 rounded-xl backdrop-blur-md z-20 border-2 border-yellow-400">
                <i data-lucide="trophy" class="w-20 h-20 text-yellow-400 mb-4 animate-bounce"></i>
                <h2 class="text-4xl font-black text-white mb-2 tracking-tighter text-center uppercase">Element Stable!</h2>
                <p id="win-message" class="text-cyan-100 font-bold mb-6 text-center"></p>
                <button onclick="shuffleGame()" class="px-10 py-4 bg-yellow-400 hover:bg-yellow-300 text-slate-900 font-black rounded-xl transition-all flex items-center gap-3 shadow-lg active:translate-y-1">
                    <i data-lucide="play" class="w-6 h-6 fill-current"></i> NEW EXPERIMENT
                </button>
            </div>
        </div>

        <div class="mt-8 flex gap-4">
            <button onclick="shuffleGame()" class="flex-1 py-4 bg-orange-500 hover:bg-orange-400 active:bg-orange-600 rounded-xl font-bold text-xl text-black transition-all flex items-center justify-center gap-2 shadow-lg active:translate-y-1 border-2 border-black">
                <i data-lucide="refresh-cw" id="shuffle-icon" class="w-6 h-6"></i>
                <span id="shuffle-text">Start Experiment</span>
            </button>
        </div>
    </div>

    <!-- HELP MODAL -->
    <div id="help-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-md z-50 flex items-center justify-center p-4">
        <div class="bg-slate-900 border-2 border-cyan-500 rounded-3xl p-8 max-w-md w-full shadow-2xl" onclick="event.stopPropagation()">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-3xl font-black text-cyan-400 uppercase tracking-tighter">Lab Protocol</h2>
                <button onclick="toggleHelp(false)" class="p-2 hover:bg-white/10 rounded-full transition-colors"><i data-lucide="x" class="w-6 h-6"></i></button>
            </div>
            <div class="space-y-6 text-slate-300">
                <section>
                    <h3 class="text-white font-bold flex items-center gap-2 mb-2"><i data-lucide="trophy" class="w-4 h-4 text-yellow-400"></i> MISSION</h3>
                    <p class="text-sm leading-relaxed">Arrange elements in atomic order by sliding them into the empty chamber.</p>
                </section>
                <section>
                    <h3 class="text-white font-bold flex items-center gap-2 mb-2"><i data-lucide="mouse-pointer-2" class="w-4 h-4 text-cyan-400"></i> INTERACTION</h3>
                    <p class="text-sm leading-relaxed">Click any adjacent element or use <span class="bg-slate-800 px-2 py-1 rounded text-white text-xs">Arrow Keys</span>.</p>
                </section>
                <div class="pt-4 border-t border-slate-800 text-center">
                    <button onclick="toggleHelp(false)" class="px-8 py-3 bg-cyan-500 hover:bg-cyan-400 text-slate-900 font-black rounded-xl transition-all shadow-md active:translate-y-1 uppercase tracking-tighter">Ready to Stabilize</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ELEMENTS DATA
        const ELEMENTS = [
            { num: 1, sym: "H", name: "Hydrogen" }, { num: 2, sym: "He", name: "Helium" },
            { num: 3, sym: "Li", name: "Lithium" }, { num: 4, sym: "Be", name: "Beryllium" },
            { num: 5, sym: "B", name: "Boron" }, { num: 6, sym: "C", name: "Carbon" },
            { num: 7, sym: "N", name: "Nitrogen" }, { num: 8, sym: "O", name: "Oxygen" },
            { num: 9, sym: "F", name: "Fluorine" }, { num: 10, sym: "Ne", name: "Neon" },
            { num: 11, sym: "Na", name: "Sodium" }, { num: 12, sym: "Mg", name: "Magnesium" },
            { num: 13, sym: "Al", name: "Aluminum" }, { num: 14, sym: "Si", name: "Silicon" },
            { num: 15, sym: "P", name: "Phosphorus" }, { num: 16, sym: "S", name: "Sulfur" },
            { num: 17, sym: "Cl", name: "Chlorine" }, { num: 18, sym: "Ar", name: "Argon" },
            { num: 19, sym: "K", name: "Potassium" }, { num: 20, sym: "Ca", name: "Calcium" }
        ];

        const LEVELS = {
            EASY: { rows: 3, cols: 3, slots: 9 },
            MEDIUM: { rows: 3, cols: 4, slots: 12 },
            HARD: { rows: 4, cols: 5, slots: 20 }
        };

        // GAME STATE
        let currentLevel = 'EASY';
        let tiles = [];
        let moves = 0;
        let seconds = 0;
        let timerInterval = null;
        let isActive = false;
        let isSolved = false;
        let showGuide = false;

        // SOUND MANAGER
        const sounds = {
            audioCtx: null,
            init() {
                if (!this.audioCtx) this.audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                if (this.audioCtx.state === 'suspended') this.audioCtx.resume();
            },
            play(type) {
                this.init();
                const ctx = this.audioCtx;
                if (!ctx) return;
                const now = ctx.currentTime;
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                if (type === 'slide') {
                    osc.frequency.setValueAtTime(400, now);
                    osc.frequency.exponentialRampToValueAtTime(100, now + 0.1);
                    gain.gain.setValueAtTime(0.05, now);
                    gain.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
                    osc.start(); osc.stop(now + 0.1);
                } else if (type === 'win') {
                    [523, 659, 783, 1046].forEach((f, i) => {
                        const o = ctx.createOscillator();
                        const g = ctx.createGain();
                        o.frequency.setValueAtTime(f, now + i * 0.1);
                        g.gain.setValueAtTime(0.05, now + i * 0.1);
                        g.gain.exponentialRampToValueAtTime(0.01, now + i * 0.1 + 0.3);
                        o.connect(g); g.connect(ctx.destination);
                        o.start(now + i * 0.1); o.stop(now + i * 0.1 + 0.3);
                    });
                }
                osc.connect(gain); gain.connect(ctx.destination);
            }
        };

        // RENDER FUNCTIONS
        function renderLobby() {
            const container = document.getElementById('level-buttons');
            container.innerHTML = Object.keys(LEVELS).map(lvl => `
                <button onclick="selectLevel('${lvl}')" class="w-full py-4 px-6 rounded-2xl border-2 transition-all flex items-center justify-between group ${currentLevel === lvl ? 'bg-cyan-500 border-cyan-400 text-slate-900 shadow-lg' : 'bg-slate-800/50 border-slate-700 text-white hover:border-cyan-500/50'}">
                    <span class="text-2xl font-black uppercase tracking-tighter">${lvl}</span>
                    <span class="opacity-80 font-black text-lg">${LEVELS[lvl].rows}x${LEVELS[lvl].cols}</span>
                </button>
            `).join('');
        }

        function renderBoard() {
            const { rows, cols, slots } = LEVELS[currentLevel];
            const grid = document.getElementById('puzzle-grid');
            const ghost = document.getElementById('ghost-layer');
            const wrapper = document.getElementById('board-wrapper');

            wrapper.style.aspectRatio = `${cols}/${rows}`;
            grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
            grid.style.gap = '6px';
            ghost.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
            ghost.style.gap = '6px';

            // Render Ghost Layer
            ghost.innerHTML = ELEMENTS.slice(0, slots).map(el => `
                <div class="flex items-center justify-center border border-white/5 bg-white/5 rounded-md">
                    <span class="text-2xl sm:text-4xl font-black text-white/[0.07] uppercase leading-none">${el.sym}</span>
                </div>
            `).join('');

            // Render Puzzle Grid
            const emptyIdx = tiles.indexOf(0);
            grid.innerHTML = tiles.map((tile, idx) => {
                if (tile === 0) return `<div class="bg-black/10 border-dashed border-2 border-black/20 rounded-md"></div>`;
                
                const element = ELEMENTS[tile - 1];
                const isCorrect = tile === idx + 1;
                const canMove = isAdjacent(idx, emptyIdx);
                
                return `
                    <button onclick="handleMove(${idx})" class="tile-transition relative flex flex-col items-center justify-center rounded-md border-[1.5px] sm:border-2 border-black bg-gradient-to-b from-yellow-300 via-yellow-400 to-orange-400 text-black shadow-md ${isCorrect && !isSolved ? 'tile-correct' : ''} ${isSolved ? 'from-green-400 via-emerald-500 to-emerald-600 border-emerald-900' : ''}">
                        <div class="flex flex-col items-center justify-between h-full py-0.5 sm:py-1 w-full px-0.5 relative">
                            <div class="flex justify-between items-start w-full px-1">
                                <span class="text-[10px] sm:text-sm font-black opacity-80">${element.num}</span>
                                ${isCorrect && !isSolved ? '<i data-lucide="check-circle-2" class="w-2.5 h-2.5 sm:w-4 sm:h-4 text-green-700/80"></i>' : ''}
                            </div>
                            <span class="text-2xl sm:text-4xl font-black leading-none my-auto drop-shadow-sm">${element.sym}</span>
                            <div class="w-full px-0.5 flex flex-col items-center gap-0.5">
                                <span class="text-[8px] sm:text-[11px] font-black uppercase tracking-tight w-full truncate text-center ${isCorrect ? 'text-green-900' : 'text-black/80'}">${element.name}</span>
                                ${canMove && !isSolved ? '<div class="absolute bottom-0 right-0 p-0.5"><div class="w-1.5 h-1.5 sm:w-3 sm:h-3 bg-black/20 rounded-full flex items-center justify-center animate-pulse"><i data-lucide="move" class="w-1 h-1 sm:w-2 sm:h-2"></i></div></div>' : ''}
                            </div>
                        </div>
                    </button>
                `;
            }).join('');
            lucide.createIcons();
        }

        // CORE LOGIC
        function selectLevel(lvl) {
            currentLevel = lvl;
            renderLobby();
        }

        function startGame() {
            document.getElementById('lobby').classList.add('hidden');
            document.getElementById('game-container').classList.remove('hidden');
            document.getElementById('current-mode').innerText = `${currentLevel} MODE`;
            initGame();
            setTimeout(shuffleGame, 300);
        }

        function exitToMenu() {
            stopTimer();
            document.getElementById('lobby').classList.remove('hidden');
            document.getElementById('game-container').classList.add('hidden');
        }

        function initGame() {
            const { slots } = LEVELS[currentLevel];
            tiles = Array.from({ length: slots - 1 }, (_, i) => i + 1);
            tiles.push(0);
            moves = 0;
            seconds = 0;
            isActive = false;
            isSolved = false;
            updateStats();
            document.getElementById('win-overlay').classList.add('hidden');
            renderBoard();
        }

        function isAdjacent(idx1, idx2) {
            const { cols } = LEVELS[currentLevel];
            const r1 = Math.floor(idx1 / cols), c1 = idx1 % cols;
            const r2 = Math.floor(idx2 / cols), c2 = idx2 % cols;
            return Math.abs(r1 - r2) + Math.abs(c1 - c2) === 1;
        }

        function handleMove(idx) {
            if (isSolved) return;
            const emptyIdx = tiles.indexOf(0);
            if (isAdjacent(idx, emptyIdx)) {
                tiles[emptyIdx] = tiles[idx];
                tiles[idx] = 0;
                moves++;
                if (!isActive) startTimer();
                sounds.play('slide');
                updateStats();
                renderBoard();
                checkWin();
            }
        }

        function shuffleGame() {
            const { rows, cols, slots } = LEVELS[currentLevel];
            initGame();
            let emptyIdx = slots - 1;
            for (let i = 0; i < 300; i++) {
                const neighbors = [];
                const r = Math.floor(emptyIdx / cols), c = emptyIdx % cols;
                if (r > 0) neighbors.push(emptyIdx - cols);
                if (r < rows - 1) neighbors.push(emptyIdx + cols);
                if (c > 0) neighbors.push(emptyIdx - 1);
                if (c < cols - 1) neighbors.push(emptyIdx + 1);
                const next = neighbors[Math.floor(Math.random() * neighbors.length)];
                [tiles[emptyIdx], tiles[next]] = [tiles[next], tiles[emptyIdx]];
                emptyIdx = next;
            }
            document.getElementById('shuffle-icon').classList.add('animate-spin-slow');
            document.getElementById('shuffle-text').innerText = 'Reshuffle';
            renderBoard();
            setTimeout(() => document.getElementById('shuffle-icon').classList.remove('animate-spin-slow'), 500);
        }

        function checkWin() {
            const { slots } = LEVELS[currentLevel];
            const won = tiles.every((t, i) => t === (i === slots - 1 ? 0 : i + 1));
            if (won && moves > 0) {
                isSolved = true;
                stopTimer();
                sounds.play('win');
                confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 } });
                document.getElementById('win-overlay').classList.remove('hidden');
                document.getElementById('win-message').innerText = `Reaction complete in ${moves} moves!`;
            }
        }

        // UTILS
        function startTimer() {
            isActive = true;
            timerInterval = setInterval(() => {
                seconds++;
                updateStats();
            }, 1000);
        }

        function stopTimer() {
            isActive = false;
            clearInterval(timerInterval);
        }

        function updateStats() {
            document.getElementById('move-count').innerText = moves;
            const m = Math.floor(seconds / 60).toString().padStart(2, '0');
            const s = (seconds % 60).toString().padStart(2, '0');
            document.getElementById('timer-display').innerText = `${m}:${s}`;
        }

        function toggleGuide() {
            showGuide = !showGuide;
            document.getElementById('ghost-layer').classList.toggle('hidden', !showGuide);
            document.getElementById('guide-status').innerText = showGuide ? 'ON' : 'OFF';
            document.getElementById('guide-btn').className = `backdrop-blur-md p-3 rounded-xl flex flex-col items-center justify-center border-2 transition-all active:scale-95 ${showGuide ? 'bg-yellow-400 border-yellow-500 text-black shadow-lg' : 'bg-black/20 border-black/30 text-white'}`;
            document.getElementById('guide-icon').className = `w-4 h-4 ${showGuide ? 'text-black' : 'text-yellow-300'}`;
            lucide.createIcons();
        }

        function toggleHelp(show) {
            document.getElementById('help-modal').classList.toggle('hidden', !show);
        }

        // KEYBOARD
        window.addEventListener('keydown', (e) => {
            const emptyIdx = tiles.indexOf(0);
            const { rows, cols } = LEVELS[currentLevel];
            const r = Math.floor(emptyIdx / cols), c = emptyIdx % cols;
            let target = -1;
            if (e.key === 'ArrowUp' && r < rows - 1) target = emptyIdx + cols;
            else if (e.key === 'ArrowDown' && r > 0) target = emptyIdx - cols;
            else if (e.key === 'ArrowLeft' && c < cols - 1) target = emptyIdx + 1;
            else if (e.key === 'ArrowRight' && c > 0) target = emptyIdx - 1;
            if (target !== -1) handleMove(target);
        });

        // INIT
        renderLobby();
        lucide.createIcons();
    </script>
</body>
</html>

